{
  "manifest_version": 3,
  "name": "XCAD",
  "version": "1.6.3.8",
  "description": "Conjunto de módulos de automação para o serviço na COGM-GM POA",
  "icons": {
    "128": "assets/icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "commands": {
    "pesquisarEfetivo": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Abre a aba de efetivo no Sentry, caso não tenha, e seleciona o campo de pesquisa por nome de guerra"
    },
    "pesquisarQTH": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q"
      },
      "description": "Abre as abas de QTH e mapa no Sentry Maps."
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/firebase-app-compat.js",
        "libs/firebase-firestore-compat.js",
        "libs/versiculos.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "web_accessible_resources/sentry/sentry.js",
        "web_accessible_resources/sentry/os.js",
        "web_accessible_resources/sentry/ba.js",
        "web_accessible_resources/sentry/despacho.js",
        "libs/jszip.js"
      ],
      "matches": [
        "https://sentry.procempa.com.br/*"
      ]
    },
    {
      "resources": [
        "content/consultas/abas_acoes.js",
        "content/consultas/dados_basicos.js",
        "content/consultas/img.js",
        "content/consultas/inicio.js",
        "content/consultas/menu_lateral.js",
        "content/consultas/ocorrencias.js",
        "content/consultas/pega_nome.js",
        "content/consultas/pesquisa_nome.js",
        "content/consultas/veiculos.js"
      ],
      "matches": [
        "https://www.consultasintegradas.rs.gov.br/*",
        "https://secweb.intra.rs.gov.br/*"
      ]
    },
    {
      "resources": [
        "content/consultas/cnj.js"
      ],
      "matches": [
        "https://portalbnmp.pdpj.jus.br/*"
      ]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content_script.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://cadweb.sinesp.gov.br/paineis-estatisticos/app/discover*"
      ],
      "js": [
        "content/sinesp/discover.js"
      ]
    },
    {
      "matches": [
        "https://cadweb.sinesp.gov.br/cad-equipe-web/*"
      ],
      "js": [
        "content/sinesp/equipes.js"
      ]
    },
    {
      "matches": [
        "https://cadweb.sinesp.gov.br/cad-ocorrencia-web/*"
      ],
      "js": [
        "content/sinesp/ocorrencias.js"
      ]
    },
    {
      "matches": [
        "https://infoseg.sinesp.gov.br/infoseg2/*"
      ],
      "js": [
        "content/sinesp/infoseg.js"
      ]
    },
    {
      "matches": [
        "https://portalbnmp.pdpj.jus.br/*"
      ],
      "js": [
        "content/consultas/cnj.js"
      ]
    },
    {
      "matches": [
        "https://www.consultasintegradas.rs.gov.br/csi/csi/INTERFACE/jsp/Individuo_Lista_Nomes_NEW.jsp?*",
        "https://secweb.intra.rs.gov.br/csi/csi/INTERFACE/jsp/Individuo_Lista_Nomes_NEW.jsp?*"
      ],
      "js": [
        "content/consultas/pega_nome.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://www.consultasintegradas.rs.gov.br/csi/csi/INTERFACE/jsp/Individuo_Consulta_DadosBasicos_NEW.jsp?",
        "https://secweb.intra.rs.gov.br/csi/csi/INTERFACE/jsp/Individuo_Consulta_DadosBasicos_NEW.jsp?*"
      ],
      "js": [
        "content/consultas/dados_basicos.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://secweb.intra.rs.gov.br/csi/csi/INTERFACE/jsp/Individuo_Consulta_Ocorrencia_NEW.jsp?*",
        "https://www.consultasintegradas.rs.gov.br/csi/csi/INTERFACE/jsp/Individuo_Consulta_Ocorrencia_NEW.jsp?*"
      ],
      "js": [
        "content/consultas/ocorrencias.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://secweb.intra.rs.gov.br/csi/csi/INTERFACE/jsp/Dados.jsp?*",
        "https://www.consultasintegradas.rs.gov.br/csi/csi/INTERFACE/jsp/Dados.jsp?*"
      ],
      "js": [
        "content/consultas/inicio.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://secweb.intra.rs.gov.br/csi/csi/INTERFACE/Html/MenuNovo.jsp",
        "https://www.consultasintegradas.rs.gov.br/csi/csi/INTERFACE/Html/MenuNovo.jsp"
      ],
      "js": [
        "content/consultas/menu_lateral.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://secweb.intra.rs.gov.br/csi/mod-veiculo/*",
        "https://www.consultasintegradas.rs.gov.br/csi/mod-veiculo/*"
      ],
      "js": [
        "content/consultas/veiculos.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "https://docs.google.com/forms*"
      ],
      "js": [
        "content/psg_servico/formulario_psg_gs.js"
      ]
    },
    {
      "matches": [
        "https://web.whatsapp.com/"
      ],
      "js": [
        "content/whatsapp/whatsapp.js"
      ]
    },
    {
      "matches": [
        "https://app.wescctech.com.br/chats*"
      ],
      "js": [
        "content/whu/whu.js"
      ]
    },
    {
      "matches": [
        "https://cercamento.procempa.com.br/*"
      ],
      "js": [
        "content/cercamento/cercamento.js"
      ]
    },
    {
      "matches": [
        "https://sso-pmpa.procempa.com.br/*"
      ],
      "js": [
        "content/cercamento/loginAutoProcempa.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation",
    "https://*.firebaseio.com/"
  ]
}
